---
import Layout from "./Layout.astro";
---

<Layout>
  <main>
    <article class="lesson-content">
      <slot />
    </article>
  </main>
</Layout>

<style>
  .lesson-content :global(h1) {
    margin-bottom: 1rem;
  }

  .lesson-content :global(h2) {
    margin-top: 3.6rem;
  }

  .lesson-content :global(h3) {
    margin-top: 2.4rem;
  }

  .lesson-content :global(pre) {
    overflow-x: auto;
    border-radius: 4px;
    border: 1px solid rgba(255, 154, 176, 0.3);
    padding: 1rem 1.15rem;
    font-size: 1rem;
    line-height: 1.7;
  }

  .lesson-content :global(pre code) {
    font-size: 1rem;
  }

  .lesson-content :global(code):not(pre code) {
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.08);
  }
</style>
